msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.TRANSPORTROUTECONFIG.TRANSPORTTRACK.TITLE"
msgid "运输轨道单包质量上限（kg）"
msgstr "Conveyor Rail Package Mass Limit (kg)"

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.TRANSPORTROUTECONFIG.TRANSPORTTRACK.TOOLTIP"
msgid "设置运输轨道上每个包裹的最大质量。原版为 20 kg，数值越大，单个包裹可承载的材料越多。"
msgstr "Sets the maximum mass of each package on conveyor rails. The vanilla value is 20 kg; higher values let each package carry more material."

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.TRANSPORTROUTECONFIG.TRANSPORTTRACK.CATEGORY"
msgid "容量与运输"
msgstr "Capacity and Transport"

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.MISCCONFIG.CATEGORY"
msgid "通用功能"
msgstr "General Features"

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.MISCCONFIG.DIGGINGDROPRATE.TITLE"
msgid "挖掘资源产出倍率"
msgstr "Digging Resource Yield Multiplier"

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.MISCCONFIG.DIGGINGDROPRATE.TOOLTIP"
msgid "调整挖掘完成时生成的资源质量。原版为 0.5；数值越大，挖掘获得的资源越多。"
msgstr "Adjusts the mass of resources generated when digging is completed. The vanilla value is 0.5; higher values produce more resources."

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.MISCCONFIG.MINIONSLEEP.TITLE"
msgid "复制人无需睡眠"
msgstr "Duplicants Do Not Need Sleep"

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.MISCCONFIG.MINIONSLEEP.TOOLTIP"
msgid "开启后，普通复制人的耐力不会自然下降，因此不会因疲劳主动睡觉。"
msgstr "When enabled, normal Duplicants do not lose stamina naturally and will not sleep because of fatigue."

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.MISCCONFIG.WATERING.TITLE"
msgid "清理液体时忽略质量限制"
msgstr "Ignore Mass Limits When Mopping"

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.MISCCONFIG.WATERING.TOOLTIP"
msgid "开启后，拖把不受液体质量上限限制，可以清理任意质量的液体。"
msgstr "When enabled, the Mop ignores the liquid mass limit and can clean up liquids of any mass."

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.MISCCONFIG.SUPERSPACESUIT.TITLE"
msgid "强化太空服属性"
msgstr "Enhanced Atmo Suit Stats"

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.MISCCONFIG.SUPERSPACESUIT.TOOLTIP"
msgid "提高太空服的挖掘、保温、耐高温和移动属性，并显著降低环境温度影响。"
msgstr "Improves the Atmo Suit's digging, insulation, heat resistance, and movement stats while greatly reducing environmental temperature effects."

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.MISCCONFIG.NOFOOD.TITLE"
msgid "复制人无需进食"
msgstr "Duplicants Do Not Need Food"

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.MISCCONFIG.NOFOOD.TOOLTIP"
msgid "开启后，普通复制人不会消耗卡路里，也不会因饥饿影响工作。"
msgstr "When enabled, normal Duplicants do not consume calories or suffer work penalties from hunger."

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.MISCCONFIG.NOBLADDER.TITLE"
msgid "复制人无需如厕"
msgstr "Duplicants Do Not Need Toilets"

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.MISCCONFIG.NOBLADDER.TOOLTIP"
msgid "开启后，普通复制人的膀胱不会增长，不需要使用厕所或厕所替代物。"
msgstr "When enabled, normal Duplicants' bladder does not fill, so they do not need toilets or latrines."

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.MISCCONFIG.NOSTRESS.TITLE"
msgid "复制人压力不会上升"
msgstr "Duplicant Stress Does Not Increase"

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.MISCCONFIG.NOSTRESS.TOOLTIP"
msgid "开启后，复制人不会获得正向压力变化；已有压力仍可通过休息和娱乐降低。"
msgstr "When enabled, Duplicants do not gain positive stress; existing stress can still decrease through rest and recreation."

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.MISCCONFIG.CARRYCAPACITY.TITLE"
msgid "复制人搬运能力倍率（x）"
msgstr "Duplicant Carry Capacity Multiplier (x)"

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.MISCCONFIG.CARRYCAPACITY.TOOLTIP"
msgid "调整普通复制人的最大搬运重量。原版为 200 kg；1.0 表示原版，2.0 表示两倍。"
msgstr "Adjusts the maximum mass normal Duplicants can carry. The vanilla value is 200 kg; 1.0 is vanilla and 2.0 is double."

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.BUILDDINGS.CATEGORY"
msgid "建筑属性"
msgstr "Building Properties"

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.BUILDDINGS.CAPACITY_TOOLTIP"
msgid "设置该建筑的储存上限，单位为 kg。"
msgstr "Sets this building's storage limit in kg."

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.BUILDDINGS.TOGGLE_TOOLTIP"
msgid "开启后，该建筑会启用标题所描述的行为；关闭后恢复原版行为。"
msgstr "When enabled, this building uses the behavior described by the option; when disabled, it uses the vanilla behavior."

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.BUILDDINGS.POWERCONSUMPTION_TOOLTIP"
msgid "设置建筑运行时的功耗，单位为 W。"
msgstr "Sets the building's active power consumption in W."

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.BUILDDINGS.GASRESERVOIR.CAPACITY"
msgid "储气库容量（kg）"
msgstr "Gas Reservoir Capacity (kg)"

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.BUILDDINGS.GASRESERVOIR.OVERHEATABLE"
msgid "允许储气库过热"
msgstr "Allow Gas Reservoir to Overheat"

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.BUILDDINGS.GASRESERVOIR.FOUNDATION"
msgid "储气库需要地基"
msgstr "Require Foundation for Gas Reservoir"

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.BUILDDINGS.LIQUIDRESERVOIR.CAPACITY"
msgid "储液库容量（kg）"
msgstr "Liquid Reservoir Capacity (kg)"

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.BUILDDINGS.LIQUIDRESERVOIR.OVERHEATABLE"
msgid "允许储液库过热"
msgstr "Allow Liquid Reservoir to Overheat"

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.BUILDDINGS.LIQUIDRESERVOIR.FOUNDATION"
msgid "储液库需要地基"
msgstr "Require Foundation for Liquid Reservoir"

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.BUILDDINGS.MINERALDEOXIDIZER.TITLE"
msgid "氧气扩散器产氧量（kg/s）"
msgstr "Electrolyzer Oxygen Output (kg/s)"

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.BUILDDINGS.MINERALDEOXIDIZER.OXYGENOUTPUT_TOOLTIP"
msgid "设置氧气扩散器每秒产出的氧气质量，单位为 kg/s。"
msgstr "Sets the mass of oxygen produced by the Electrolyzer each second, in kg/s."

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.BUILDDINGS.MINERALDEOXIDIZER.ENERGYCONSUMPTIONWHENACTIVE"
msgid "氧气扩散器运行功耗（W）"
msgstr "Electrolyzer Active Power Consumption (W)"

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.BUILDDINGS.MINERALDEOXIDIZER.FLOODABLE"
msgid "允许氧气扩散器被淹没"
msgstr "Allow Electrolyzer to Be Flooded"

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.BUILDDINGS.MINERALDEOXIDIZER.OVERHEATABLE"
msgid "允许氧气扩散器过热"
msgstr "Allow Electrolyzer to Overheat"

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.BUILDDINGS.MINERALDEOXIDIZER.HEATGENERATION"
msgid "氧气扩散器产生自热"
msgstr "Electrolyzer Generates Heat"

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.BUILDDINGS.MINERALDEOXIDIZER.OUTPUTTEMPERATURE"
msgid "产出氧气温度（°C）"
msgstr "Oxygen Output Temperature (°C)"

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.BUILDDINGS.MINERALDEOXIDIZER.OUTPUTTEMPERATURE_TOOLTIP"
msgid "设置氧气扩散器产出氧气的温度，单位为 °C。"
msgstr "Sets the temperature of the oxygen produced by the Electrolyzer, in °C."

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.BUILDDINGS.POWERTRANSFORMERSMALL.HEATGENERATION"
msgid "小型变压器产生自热"
msgstr "Small Transformer Generates Heat"

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.BUILDDINGS.POWERTRANSFORMER.HEATGENERATION"
msgid "大型变压器产生自热"
msgstr "Large Transformer Generates Heat"

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.BUILDDINGS.REFRIGERATOR.ENERGYCONSUMPTIONWHENACTIVE"
msgid "冰箱运行功耗（W）"
msgstr "Refrigerator Active Power Consumption (W)"

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.BUILDDINGS.REFRIGERATOR.FLOODABLE"
msgid "允许冰箱被淹没"
msgstr "Allow Refrigerator to Be Flooded"

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.BUILDDINGS.REFRIGERATOR.OVERHEATABLE"
msgid "允许冰箱过热"
msgstr "Allow Refrigerator to Overheat"

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.BUILDDINGS.REFRIGERATOR.CAPACITY"
msgid "冰箱容量（kg）"
msgstr "Refrigerator Capacity (kg)"

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.BUILDDINGS.SOLIDCONDUITOUTBOX.CAPACITY"
msgid "运输存放器容量（kg）"
