msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.PLANTCONFIG.PLANT.ENABLECROPPATCH"
msgid "启用作物调整"
msgstr "Enable Crop Adjustments"

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.PLANTCONFIG.PLANT.ENABLECROPPATCH_TOOLTIP"
msgid "开启后，下面的植物生长周期和每次收获数量设置才会生效。"
msgstr "When enabled, the plant growth cycle and harvest amount settings below take effect."

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.PLANTCONFIG.PLANT.CROPDURATION"
msgid "生长周期（秒）"
msgstr "Growth Cycle (s)"

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.PLANTCONFIG.PLANT.CROPDURATION_TOOLTIP"
msgid "植物完成一次生长所需的时间，单位为秒；数值越小，成熟越快。"
msgstr "The time a plant needs to complete one growth cycle, in seconds. Lower values make plants mature faster."

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.PLANTCONFIG.PLANT.NUMPRODUCED"
msgid "每次收获数量"
msgstr "Harvest Amount"

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.PLANTCONFIG.PLANT.NUMPRODUCED_TOOLTIP"
msgid "植物每次成熟时产出的数量。"
msgstr "The amount produced by the plant each time it matures."

