msgstr "Storage Bin Capacity (kg)"

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.POWERCONFIG.WIRING.CATEGORY"
msgid "电线容量"
msgstr "Wire Capacity"

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.POWERCONFIG.WIRING.TOOLTIP"
msgid "设置对应电线的最大输电功率，单位以选项标题为准。"
msgstr "Sets the maximum power transmission for each wire type; use the unit shown in the option title."

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.POWERCONFIG.WIRING.WIRE500W"
msgid "500 W 线路最大功率（W）"
msgstr "500 W Wire Maximum Power (W)"

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.POWERCONFIG.WIRING.WIRES"
msgid "普通电线最大功率（kW）"
msgstr "Wire Maximum Power (kW)"

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.POWERCONFIG.WIRING.CONDUCTORS"
msgid "导电线最大功率（kW）"
msgstr "Conductive Wire Maximum Power (kW)"

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.POWERCONFIG.WIRING.RUBBERWIRES"
msgid "橡胶电线最大功率（kW）"
msgstr "Rubber Wire Maximum Power (kW)"

msgctxt "MiniBox.STRINGS.CONFIGURATIONITEM.POWERCONFIG.WIRING.HIGHLOADWIRES"
