msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKCORE.NAME"
msgid "储存网络核心"
msgstr "Storage Network Core"

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKCORE.DESC"
msgid "维持储存网络运行的核心节点。"
msgstr "The core node that keeps the Storage Network running."

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKCORE.EFFECT"
msgid "提供大容量通用储存，并作为储存网络的主要基础设施。"
msgstr "Provides large general-purpose storage and acts as the main Storage Network infrastructure."

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKORDERPRODUCTIONCENTER.NAME"
msgid "订单生产中心"
msgstr "Order Production Center"

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKORDERPRODUCTIONCENTER.DESC"
msgid "用于刻录制造台配方并承接订单生产的网络建筑。"
msgstr "A network building that engraves production building recipes and handles production orders."

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKORDERPRODUCTIONCENTER.EFFECT"
msgid "点击“刻录”后选择一个带配方的生产建筑，将它的配方刻录到订单生产中心；源建筑会被销毁，同一配方只能刻录一次。"
msgstr "Click \"Engrave\" and select a production building with recipes to engrave its recipes into the Order Production Center. The source building is destroyed, and each recipe can only be engraved once."

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKSMALLSOLIDSERVER.NAME"
msgid "小型固体服务器"
msgstr "Small Solid Server"

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKSMALLSOLIDSERVER.DESC"
msgid "用于接入 <link=\"STORAGENETWORK\">储存网络</link> 的小型固体储存服务器。固体物品需要通过 <link=\"STORAGENETWORKSOLIDINPUTPORT\">材料入网端口</link> 存入网络。"
msgstr "A small solid storage server for the <link=\"STORAGENETWORK\">Storage Network</link>. Solid items must be stored into the network through a <link=\"STORAGENETWORKSOLIDINPUTPORT\">Material Network Input Port</link>."

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKSMALLSOLIDSERVER.EFFECT"
msgid "储存固体物品，并显示在 <link=\"STORAGENETWORK\">储存网络</link> 窗口中。复制人可以像普通储物箱一样从这里取出物品；关闭“允许人力操作”后将禁止复制人手动取物。"
msgstr "Stores solid items and appears in the <link=\"STORAGENETWORK\">Storage Network</link> window. Duplicants can take items from here like a normal storage bin; disabling \"Allow Manual Use\" prevents duplicants from manually taking items."

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKSOLIDINPUTPORT.NAME"
msgid "材料入网端口"
msgstr "Material Network Input Port"

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKSOLIDINPUTPORT.DESC"
msgid "将固体运输轨道连接到储存网络的输入端口。"
msgstr "An input port that connects solid conveyor rails to the Storage Network."

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKSOLIDINPUTPORT.EFFECT"
msgid "用于接收运输轨道上的固体材料，并作为后续入网逻辑的连接建筑。"
msgstr "Receives solid materials from conveyor rails and acts as the connection building for future network input logic."

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKSOLIDOUTPUTPORT.NAME"
msgid "材料出网端口"
msgstr "Material Network Output Port"

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKSOLIDOUTPUTPORT.DESC"
msgid "将储存网络连接到固体运输轨道的输出端口。"
msgstr "An output port that connects the Storage Network to solid conveyor rails."

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKSOLIDOUTPUTPORT.EFFECT"
msgid "用于向运输轨道输出固体材料，并作为后续出网逻辑的连接建筑。"
msgstr "Outputs solid materials to conveyor rails and acts as the connection building for future network output logic."

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKLIQUIDINPUTPORT.NAME"
msgid "液体入网端口"
msgstr "Liquid Network Input Port"

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKLIQUIDINPUTPORT.DESC"
msgid "将液体管道连接到储存网络的输入端口。"
msgstr "An input port that connects liquid pipes to the Storage Network."

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKLIQUIDINPUTPORT.EFFECT"
msgid "用于接收管道中的液体，并作为后续入网逻辑的连接建筑。"
msgstr "Receives liquids from pipes and acts as the connection building for future network input logic."

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKLIQUIDOUTPUTPORT.NAME"
msgid "液体出网端口"
msgstr "Liquid Network Output Port"

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKLIQUIDOUTPUTPORT.DESC"
msgid "将储存网络连接到液体管道的输出端口。"
msgstr "An output port that connects the Storage Network to liquid pipes."

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKLIQUIDOUTPUTPORT.EFFECT"
msgid "用于向管道输出液体，并作为后续出网逻辑的连接建筑。"
msgstr "Outputs liquids to pipes and acts as the connection building for future network output logic."

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKGASINPUTPORT.NAME"
msgid "气体入网端口"
msgstr "Gas Network Input Port"

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKGASINPUTPORT.DESC"
msgid "将气体管道连接到储存网络的输入端口。"
msgstr "An input port that connects gas pipes to the Storage Network."

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKGASINPUTPORT.EFFECT"
msgid "用于接收管道中的气体，并作为后续入网逻辑的连接建筑。"
msgstr "Receives gases from pipes and acts as the connection building for future network input logic."

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKGASOUTPUTPORT.NAME"
msgid "气体出网端口"
msgstr "Gas Network Output Port"

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKGASOUTPUTPORT.DESC"
msgid "将储存网络连接到气体管道的输出端口。"
msgstr "An output port that connects the Storage Network to gas pipes."

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKGASOUTPUTPORT.EFFECT"
msgid "用于向管道输出气体，并作为后续出网逻辑的连接建筑。"
msgstr "Outputs gases to pipes and acts as the connection building for future network output logic."

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKPOWERINPUTPORT.NAME"
msgid "电力入网端口"
msgstr "Power Network Input Port"

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKPOWERINPUTPORT.DESC"
msgid "将电路连接到储存网络的电力输入端口。"
msgstr "A power input port that connects circuits to the Storage Network."

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKPOWERINPUTPORT.EFFECT"
msgid "用于接入电力网络，并作为后续电力入网逻辑的连接建筑。"
msgstr "Connects to an electrical circuit and acts as the connection building for future power input logic."

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKPOWEROUTPUTPORT.NAME"
msgid "电力出网端口"
msgstr "Power Network Output Port"

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKPOWEROUTPUTPORT.DESC"
msgid "将储存网络连接到电路的电力输出端口。"
msgstr "A power output port that connects the Storage Network to circuits."

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKPOWEROUTPUTPORT.EFFECT"
msgid "用于向电路输出电力，并作为后续电力出网逻辑的连接建筑。"
msgstr "Outputs power to an electrical circuit and acts as the connection building for future power output logic."

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKSMALLLIQUIDSERVER.NAME"
