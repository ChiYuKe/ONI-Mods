msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKPARTICLEINPUTPORT.EFFECT"
msgid "捕获经过端口的高能粒子，并将粒子存入同星球的粒子服务器。"
msgstr "Captures high-energy particles passing through the port and stores them in particle servers on the same asteroid."

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKPARTICLEOUTPUTPORT.NAME"
msgid "粒子出网端口"
msgstr "Particle Network Output Port"

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKPARTICLEOUTPUTPORT.DESC"
msgid "将储存网络中的高能粒子发射出去的输出端口。"
msgstr "An output port that fires high-energy particles from the storage network."

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKPARTICLEOUTPUTPORT.EFFECT"
msgid "从同星球的粒子服务器中取出高能粒子，并向右发射。"
msgstr "Draws high-energy particles from particle servers on the same asteroid and fires them to the right."

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKSMALLPARTICLESERVER.NAME"
msgid "小型粒子服务器"
msgstr "Small Particle Server"

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKSMALLPARTICLESERVER.DESC"
msgid "用于接入储存网络的小型高能粒子储存服务器。"
msgstr "A small high-energy particle storage server for the storage network."

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKSMALLPARTICLESERVER.EFFECT"
msgid "储存高能粒子，并供粒子出网端口发射。"
msgstr "Stores high-energy particles for particle output ports."

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKMEDIUMPARTICLESERVER.NAME"
msgid "中型粒子服务器"
msgstr "Medium Particle Server"

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKMEDIUMPARTICLESERVER.DESC"
msgid "用于接入储存网络的中型高能粒子储存服务器。"
msgstr "A medium high-energy particle storage server for the storage network."

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKMEDIUMPARTICLESERVER.EFFECT"
msgid "储存更多高能粒子，并供粒子出网端口发射。"
msgstr "Stores more high-energy particles for particle output ports."

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKLARGEPARTICLESERVER.NAME"
msgid "大型粒子服务器"
msgstr "Large Particle Server"

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKLARGEPARTICLESERVER.DESC"
msgid "用于接入储存网络的大型高能粒子储存服务器。"
msgstr "A large high-energy particle storage server for the storage network."

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKLARGEPARTICLESERVER.EFFECT"
msgid "储存大量高能粒子，并供粒子出网端口发射。"
msgstr "Stores a large amount of high-energy particles for particle output ports."

