msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKRELAYMODULE.NAME"
msgid "储存网络中继器"
msgstr "Storage Network Relay"

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKRELAYMODULE.DESC"
msgid "安装在火箭上的储存网络中继舱。"
msgstr "A Storage Network relay module installed on rockets."

msgctxt "StorageNetwork.STRINGS.BUILDINGS.PREFABS.STORAGENETWORKRELAYMODULE.EFFECT"
msgid "火箭发射到太空后，允许储存网络跨星球传输物品。"
msgstr "When the rocket is in space, allows the Storage Network to transfer items between planetoids."

msgctxt "StorageNetwork.STRINGS.ITEMS.INDUSTRIAL_PRODUCTS.STORAGE_NETWORK_ENGRAVING_DISK.NAME"
msgid "刻录盘"
msgstr "Engraving Disk"

msgctxt "StorageNetwork.STRINGS.ITEMS.INDUSTRIAL_PRODUCTS.STORAGE_NETWORK_ENGRAVING_DISK.DESC"
msgid "用于保存 <link=\"STORAGENETWORKORDERPRODUCTIONCENTER\">订单生产中心</link> 刻录出的配方数据，并为订单生产中心提供 1 个生产核心。"
msgstr "Stores recipe data engraved by an <link=\"STORAGENETWORKORDERPRODUCTIONCENTER\">Order Production Center</link> and provides 1 production core for the center."

msgctxt "StorageNetwork.STRINGS.ITEMS.INDUSTRIAL_PRODUCTS.STORAGE_NETWORK_ENGRAVING_DISK.RECIPEDESC"
msgid ""
"制造一张空白刻录盘，可放入 <link=\"STORAGENETWORKORDERPRODUCTIONCENTER\">订单生产中心</link>，保存刻录出的生产配方，并提供 1 个生产核心。\n"
"\n"
"生产方：<link=\"CRAFTINGTABLE\">工作台</link>、<link=\"SUPERMATERIALREFINERY\">分子熔炉</link>。"
msgstr ""
"Produces a blank Engraving Disk. Insert it into an <link=\"STORAGENETWORKORDERPRODUCTIONCENTER\">Order Production Center</link> to store engraved production recipes and provide 1 production core.\n"
"\n"
"Produced by: <link=\"CRAFTINGTABLE\">Crafting Station</link>, <link=\"SUPERMATERIALREFINERY\">Molecular Forge</link>."

msgctxt "StorageNetwork.STRINGS.RESEARCH.TECHS.STORAGENETWORK.NAME"
msgid "储存网络"
msgstr "Storage Network"

msgctxt "StorageNetwork.STRINGS.RESEARCH.TECHS.STORAGENETWORK.DESC"
msgid "解锁储存网络核心、服务器和跨星球中继设备。"
msgstr "Unlocks the Storage Network core, servers, and interplanetary relay equipment."

msgctxt "StorageNetwork.STRINGS.RESEARCH.TECHS.STORAGENETWORKCORE.NAME"
msgid "储存核心"
msgstr "Storage Core"

msgctxt "StorageNetwork.STRINGS.RESEARCH.TECHS.STORAGENETWORKCORE.DESC"
msgid "解锁储存网络核心。"
msgstr "Unlocks the Storage Network Core."

msgctxt "StorageNetwork.STRINGS.RESEARCH.TECHS.STORAGENETWORKPORTS.NAME"
msgid "网络端口"
msgstr "Network Ports"

msgctxt "StorageNetwork.STRINGS.RESEARCH.TECHS.STORAGENETWORKPORTS.DESC"
msgid "解锁材料、液体、气体和电力的储存网络入网与出网端口。"
msgstr "Unlocks Storage Network input and output ports for materials, liquids, gases, and power."

msgctxt "StorageNetwork.STRINGS.RESEARCH.TECHS.STORAGENETWORKSMALLSTORAGE.NAME"
msgid "小型储存"
msgstr "Small Storage"

msgctxt "StorageNetwork.STRINGS.RESEARCH.TECHS.STORAGENETWORKSMALLSTORAGE.DESC"
msgid "解锁小型固体、液体、气体、电池和冷库服务器。"
msgstr "Unlocks small solid, liquid, gas, battery, and cold storage servers."

msgctxt "StorageNetwork.STRINGS.RESEARCH.TECHS.STORAGENETWORKMEDIUMSTORAGE.NAME"
msgid "中级储存"
msgstr "Medium Storage"

msgctxt "StorageNetwork.STRINGS.RESEARCH.TECHS.STORAGENETWORKMEDIUMSTORAGE.DESC"
msgid "解锁中型固体、液体、气体、电池和冷库服务器。"
msgstr "Unlocks medium solid, liquid, gas, battery, and cold storage servers."

msgctxt "StorageNetwork.STRINGS.RESEARCH.TECHS.STORAGENETWORKORDERPRODUCTION.NAME"
msgid "订单生产中心"
msgstr "Order Production Center"

msgctxt "StorageNetwork.STRINGS.RESEARCH.TECHS.STORAGENETWORKORDERPRODUCTION.DESC"
msgid "解锁可刻录制造台配方并承接订单生产的订单生产中心。"
msgstr "Unlocks the Order Production Center for engraving production building recipes and fulfilling production orders."

